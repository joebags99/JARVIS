# ─────────────────────────────────────────────────────────────
# JARVIS — keep ALL personal data and secrets OFF GitHub
# ─────────────────────────────────────────────────────────────

# Secrets & API keys
.env
*.env
!.env.example

# OAuth / auth tokens & credentials (NEVER commit)
token.json
*token*.json
credentials.json
*credentials*.json
.msal_cache.bin
*.cache.bin
tokens/

# Personal context (your jobs, profile, D&D notes, etc.)
knowledge_pools.json
JARVIS/

# Meal-prep cycles (your dinner plans/shopping lists)
meal_plans.json

# JARVIS voice-dial defaults (persisted personality tweaks)
persona_dials.json

# Fantasy/proper-name corrections glossary (your character names)
name_corrections.json

# Settings-panel overrides (your categories, etc.)
jarvis_config.json

# User-defined MCP server list (may reference env vars holding secrets;
# copy mcp_servers.example.json to get started)
mcp_servers.json

# Long-term memory store (your facts + past session summaries)
memory.db
memory.db-journal
memory.db-wal
memory.db-shm

# Obsidian vault search index (rebuildable cache over your vault's markdown)
vault_index.db
vault_index.db-journal
vault_index.db-wal
vault_index.db-shm

# Everything in /context except the committed example templates.
context/*
!context/*.example.md
!context/.gitkeep

# Meeting notes — private by definition
notes/*
!notes/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# Generated runtime assets
assets/tray_icon.png

# Whisper / model caches
*.bin
models/
.cache/

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Recordings / temp audio
*.wav
temp/
tmp/

# Usage-pricing overrides (optional, personal)
jarvis_usage_prices.json

# Vault taxonomy overrides (optional, personal categories)
vault_config.json
