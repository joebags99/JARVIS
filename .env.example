# ─────────────────────────────────────────────────────────────
# JARVIS configuration — copy this file to ".env" and fill it in.
#   cp .env.example .env
# The real .env is gitignored and never leaves your machine.
# ─────────────────────────────────────────────────────────────

# ── Anthropic (REQUIRED) ─────────────────────────────────────
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model used for responses.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cheap model used only for throwaway summaries (session recaps + history
# compaction). Defaults to Haiku; those calls don't need the main model.
ANTHROPIC_SUMMARY_MODEL=claude-haiku-4-5

# ── App settings ─────────────────────────────────────────────
JARVIS_USER_NAME=Joe

# Overlay start position: top-right | top-left | bottom-right | bottom-left
JARVIS_WINDOW_POSITION=top-right

# Global hotkey to toggle the overlay from anywhere (optional).
# Leave blank to disable. Example: ctrl+space
JARVIS_HOTKEY=ctrl+space

# Default location for weather / daily briefing when you don't name a city.
# Leave blank and JARVIS will ask. Example: Chicago, IL
JARVIS_LOCATION=

# Max characters of context to assemble before truncating oldest notes.
# (~4 chars per token, so 32000 chars ≈ 8000 tokens.)
JARVIS_MAX_CONTEXT_CHARS=32000

# IANA timezone override (e.g. America/Chicago) for calendar events created
# without a UTC offset. Leave blank to auto-detect from the system.
JARVIS_TIMEZONE=

# ── Speech-to-text (optional) ────────────────────────────────
# Whisper model size: tiny | base | small | medium
# Downloaded automatically on first voice use. "small" is a good balance.
WHISPER_MODEL=small

# Glossary that corrects misheard/misspelled proper names (voice + typed) and
# biases Whisper toward them. Copy name_corrections.example.json → the path below.
NAME_CORRECTIONS_FILE=name_corrections.json
# How close an unlisted capitalized word must be (0-1) to auto-snap to a known
# name. 0.85 is safe (only near-certain typos); lower (~0.78) = more aggressive.
NAME_FUZZY_CUTOFF=0.85

# ── Text-to-speech (optional) ────────────────────────────────
# Have JARVIS read replies aloud. Off by default; toggle live with the speaker
# button or the "Speak Replies" tray item. Install the deps your engine needs
# (see requirements.txt).
TTS_ENABLED=false
# Engine: edge (free neural, online — reply text goes to Microsoft)
#       | system (pyttsx3, offline/private, robotic)
#       | elevenlabs (premium, needs ELEVENLABS_API_KEY below)
TTS_ENGINE=edge
# Engine-specific voice. Blank uses the engine default.
#   edge: a voice short name, e.g. en-GB-RyanNeural, en-US-GuyNeural
#   system: a substring of an installed OS voice name, e.g. David, Zira
#   elevenlabs: a voice id (otherwise ELEVENLABS_VOICE_ID is used)
TTS_VOICE=
# pyttsx3 speaking rate in words/min (system engine only).
TTS_RATE=175
# ElevenLabs (only when TTS_ENGINE=elevenlabs).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Google Calendar (optional — leave blank to skip) ─────────
# Download an OAuth client (Desktop app) credentials.json from
# https://console.cloud.google.com/  →  point this at the file.
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── Outlook / Microsoft Graph (optional — leave blank to skip) ──
# Register an app at https://portal.azure.com/ (Azure AD app registration).
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=common
OUTLOOK_CLIENT_SECRET=

# ── Outlook ICS feed (optional — fallback when you can't get an Azure ──
# app registration; busy/free only, no titles/locations) ─────────────
# Outlook on the web → Settings → Calendar → Shared calendars →
# Publish a calendar → copy the ICS link.
# WARNING: this URL is a bearer secret — anyone with it can see your
# busy/free times. Never share it or commit it anywhere.
OUTLOOK_ICS_URL=

# ── Todoist (optional — leave blank to skip) ──────────────────
# Personal API token from Todoist: Settings → Integrations → Developer.
TODOIST_API_KEY=

# ── Gmail (optional) ─────────────────────────────────────────
# Reuses the Google credentials.json above but needs its own consent for mail
# scopes, so it's opt-in. Set to true to surface the email read/draft tools;
# first use opens a browser to authorize. JARVIS only reads mail and writes
# drafts for you to review — it never sends mail on its own.
GMAIL_ENABLED=false
# Which Google accounts to use for Gmail (comma-separated names). Each gets its
# own mail token under tokens/google_mail/{name}.json, and you pick the matching
# Google login in the browser the first time each is used. Leave blank to reuse
# the calendar's GOOGLE_ACCOUNTS list. For 3 separate inboxes, e.g.:
#   GMAIL_ACCOUNTS=personal,work,side
GMAIL_ACCOUNTS=

# ── Monarch Money (optional) ─────────────────────────────────
# Connects via Monarch's official MCP server using OAuth — no password stored.
# Set to true, then on first financial question a browser opens to authorize.
# Token is cached; re-auth only needed if you revoke access.
MONARCH_ENABLED=false

# ── Spotify (optional) ───────────────────────────────────────
# Play/control music by voice or chat. Requires Spotify PREMIUM and an open
# Spotify device (the Web API can only control playback under those conditions).
# Setup: create an app at https://developer.spotify.com/dashboard, then under
# its settings add this Redirect URI EXACTLY (must be the loopback IP, not
# "localhost"):
#     http://127.0.0.1:9433/callback
# Copy the app's Client ID below (no client secret needed — JARVIS uses PKCE).
# Set to true, then on the first music request a browser opens to authorize.
SPOTIFY_ENABLED=false
SPOTIFY_CLIENT_ID=
